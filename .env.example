# AIORA Business UI Environment Configuration

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configuration (Client-side only)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Environment
NODE_ENV=development

# ─── Dev Auth (local testing only) ───────────────────────────────────────────
# Set NEXT_PUBLIC_SKIP_AUTH=true to bypass Google OAuth and use a mock seller.
# This ONLY works when NODE_ENV !== 'production'. Never set this in production.
# NEXT_PUBLIC_SKIP_AUTH=true
# NEXT_PUBLIC_DEV_SELLER_ID=dev-seller-001
# NEXT_PUBLIC_DEV_SELLER_NAME=Dev Seller
# NEXT_PUBLIC_DEV_PHONE=9999999999